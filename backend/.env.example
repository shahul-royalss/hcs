# Dhrishta Healthcare Services backend configuration.
# Copy to .env and fill in real values. NEVER commit .env.

# --- MongoDB ---
# Connection string for MongoDB (local default shown).
MONGO_URL=mongodb://localhost:27017
# Database name.
DB_NAME=dhrishta_healthcare

# --- Auth / JWT ---
# Secret used to sign JWTs (HS256). REQUIRED in production — the default is
# an insecure development value and the server logs a warning when used.
JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime in minutes (default 1440 = 24 hours).
JWT_EXPIRES_MINUTES=1440

# --- Stripe payments ---
# Secret API key (sk_live_... / sk_test_...). Leave empty to disable payments
# (endpoints return {"status": "disabled"} instead of failing).
STRIPE_SECRET_KEY=

# --- Twilio (SMS + WhatsApp) ---
# Account credentials from the Twilio console. Leave empty to disable.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender numbers in E.164 format, e.g. +14155238886.
TWILIO_WHATSAPP_NUMBER=
TWILIO_SMS_NUMBER=

# --- Resend (transactional email) ---
# API key from resend.com. Leave empty to disable outbound email.
RESEND_API_KEY=

# --- AI chatbot (Anthropic Messages API) ---
# API key for the AI chatbot. Leave empty to use the built-in rule-based
# fallback assistant (no external calls).
AI_MODEL_API_KEY=
# Model id used for chat replies.
AI_MODEL=claude-sonnet-4-5

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# --- First admin account ---
# Auto-created on backend startup when the users collection is empty
# (also used by scripts/seed_data.py). CHANGE the password after first login.
ADMIN_EMAIL=admin@dhrishta.com
SEED_ADMIN_PASSWORD=ChangeMe@123
